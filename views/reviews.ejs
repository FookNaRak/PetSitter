<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>รีวิวพี่เลี้ยง</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-indigo-50 min-h-screen font-sans">
  <%- include('partials/header', { user: user }) %>

  <section class="py-16 px-6 max-w-lg mx-auto bg-white rounded-2xl shadow">
    <h2 class="text-2xl font-bold text-indigo-700 mb-4">รีวิวพี่เลี้ยง</h2>

    <% if (error) { %>
      <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4"><%= success %></div>
    <% } %>

    <% if(reviews.length > 0){ %>
      <div class="mb-6">
        <% reviews.forEach(r => { %>
          <div class="border-b py-2">
            <p>⭐ <%= r.rating %> - <%= r.comment %></p>
            <p class="text-sm text-gray-500">โดย <%= r.user %></p>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p class="mb-4">ยังไม่มีรีวิว</p>
    <% } %>

    <form action="/reviews/<%= sitterId %>" method="POST" class="flex flex-col gap-4">
      <label>คะแนน (1-5): <input type="number" name="rating" min="1" max="5" required class="border px-2 py-1 rounded w-full"></label>
      <label>ความคิดเห็น: <textarea name="comment" class="border px-2 py-1 rounded w-full"></textarea></label>
      <button type="submit" class="bg-yellow-500 hover:bg-yellow-600 text-white px-4 py-2 rounded-lg">ส่งรีวิว</button>
    </form>
  </section>
</body>
</html>
