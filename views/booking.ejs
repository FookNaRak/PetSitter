<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>จองคิว</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-indigo-50 min-h-screen font-sans">
  <%- include('partials/header', { user: user }) %>

  <section class="py-16 px-6 max-w-md mx-auto bg-white rounded-2xl shadow">
    <h2 class="text-2xl font-bold text-indigo-700 mb-4">จองคิวพี่เลี้ยง</h2>
    <form action="/booking/<%= sitterId %>" method="POST" class="flex flex-col gap-4">
      <label>วัน: <input type="date" name="date" required class="border px-2 py-1 rounded w-full"></label>
      <label>เวลา: <input type="time" name="time" required class="border px-2 py-1 rounded w-full"></label>
      <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg">จอง</button>
    </form>
  </section>
</body>
</html>
