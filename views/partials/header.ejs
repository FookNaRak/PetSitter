<header class="bg-indigo-600 text-white py-4 shadow-md">
  <div class="container mx-auto flex justify-between items-center px-6">
    <h1 class="text-2xl font-bold tracking-wide">🐶 Pet Sitter Platform</h1>
    <nav class="space-x-4">
      <a href="/" class="hover:underline">หน้าแรก</a>
      <a href="/sitters" class="hover:underline">พี่เลี้ยง</a>
      <% if(user){ %>
        <span>สวัสดี, <%= user.name %>!</span>
        <a href="/logout" class="bg-white text-indigo-600 px-3 py-1 rounded-lg font-semibold hover:bg-indigo-50">ออกจากระบบ</a>
      <% } else { %>
        <a href="/login" class="hover:underline">เข้าสู่ระบบ</a>
        <a href="/register" class="hover:underline">สมัครสมาชิก</a>
      <% } %>
    </nav>
  </div>
</header>
