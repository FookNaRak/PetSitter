<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>โปรไฟล์พี่เลี้ยง 🐾</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-indigo-50 min-h-screen font-sans">

  <%- include('partials/header', { user: user }) %>

  <!-- ข้อมูลพี่เลี้ยง -->
  <section class="py-16 px-6 text-center max-w-3xl mx-auto bg-white rounded-2xl shadow">
    <h2 class="text-3xl font-bold text-indigo-700 mb-4"><%= sitter.name %></h2>
    <p>ประสบการณ์: <%= sitter.experience %> ปี</p>
    <p>ราคา: <%= sitter.price %> บาท/วัน</p>
    <p>พื้นที่ให้บริการ: <%= sitter.location %></p>
  </section>

  <!-- ปุ่มจอง / รีวิว -->
  <section class="py-6 px-6 max-w-3xl mx-auto text-center">
    <% if(user){ %>
      <div class="space-x-4">
        <a href="/booking/<%= sitter.id %>" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-lg font-semibold">
          จองพี่เลี้ยง
        </a>
        <a href="/reviews/<%= sitter.id %>" class="bg-yellow-500 hover:bg-yellow-600 text-white px-6 py-2 rounded-lg font-semibold">
          เขียนรีวิว
        </a>
      </div>
    <% } else { %>
      <p class="text-gray-600">ต้อง <a href="/login" class="text-indigo-600 hover:underline">เข้าสู่ระบบ</a> เพื่อจองหรือรีวิว</p>
    <% } %>
  </section>

  <!-- รีวิวของพี่เลี้ยง -->
  <section class="py-8 px-6 max-w-3xl mx-auto">
    <h3 class="text-2xl font-semibold text-indigo-700 mb-4">รีวิวจากเจ้าของสัตว์</h3>
    <% if (reviews.length === 0) { %>
      <p class="text-gray-600">ยังไม่มีรีวิวสำหรับพี่เลี้ยงคนนี้</p>
    <% } else { %>
      <div class="space-y-4">
        <% reviews.forEach(review => { %>
          <div class="bg-indigo-50 p-4 rounded-lg shadow">
            <div class="flex justify-between items-center mb-2">
              <span class="font-semibold"><%= review.user_name %></span>
              <span class="text-yellow-500">⭐ <%= review.rating %>/5</span>
            </div>
            <p class="text-gray-700"><%= review.comment %></p>
            <small class="text-gray-500"><%= new Date(review.created_at).toLocaleDateString() %></small>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>

</body>
</html>
