<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>สมัครพี่เลี้ยง 🐾</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-indigo-50 min-h-screen font-sans">

  <%- include('partials/header', { user: user }) %>

  <section class="py-16 px-6 max-w-md mx-auto bg-white rounded-2xl shadow">
    <h2 class="text-3xl font-bold text-indigo-700 mb-6">สมัครเป็นพี่เลี้ยงสัตว์</h2>

    <form action="/sitters/register" method="POST" class="space-y-4">
      <div>
        <label class="block text-gray-700">ประสบการณ์ (ปี)</label>
        <input type="number" name="experience" class="w-full px-4 py-2 rounded-lg border" required>
      </div>
      <div>
        <label class="block text-gray-700">ราคา/วัน (บาท)</label>
        <input type="number" name="price" class="w-full px-4 py-2 rounded-lg border" required>
      </div>
      <div>
        <label class="block text-gray-700">พื้นที่ให้บริการ</label>
        <input type="text" name="location" class="w-full px-4 py-2 rounded-lg border" required>
      </div>
      <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2 rounded-lg font-semibold w-full">สมัคร</button>
    </form>
  </section>

</body>
</html>
